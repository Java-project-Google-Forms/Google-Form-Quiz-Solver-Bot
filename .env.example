# Copy to .env and fill in real values before running docker compose

TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# GigaChat API key
GIGACHAT_API_KEY=your-gigachat-api-key

# MongoDB
MONGODB_DATABASE=quiz_bot

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-in-production

# Docker image name and tag (used when pushing to Docker Hub)
DOCKER_IMAGE=dockerhub-username/google-form-quiz-bot
VERSION=latest

# Host port to expose the app on (default 8080)
APP_PORT=8080
